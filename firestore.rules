rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email.lower() == 'raviranjan8904@gmail.com';
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Students collection rules
    match /students/{studentId} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == studentId);
    }

    // Enrollments collection rules
    match /enrollments/{enrollmentId} {
      allow create: if isAdmin() || (isSignedIn()
                    && incoming().email.lower() == request.auth.token.email.lower());
      allow list: if isAdmin() || (isSignedIn()
                  && (resource.data.email.lower() == request.auth.token.email.lower()));
      allow get: if true; // Public verification of individual certificate IDs allowed
      allow update: if isAdmin() || (isSignedIn()
                    && (resource.data.email.lower() == request.auth.token.email.lower())
                    && incoming().email.lower() == request.auth.token.email.lower());
      allow delete: if isAdmin() || (isSignedIn()
                    && (resource.data.email.lower() == request.auth.token.email.lower()));
    }

    // Domains collection - public read, admin write
    match /domains/{domainId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Study Materials - authenticated read, admin write
    match /studyMaterials/{materialId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // MCQ Questions - authenticated read, admin write
    match /mcqQuestions/{questionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Test Results
    match /testResults/{resultId} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || (isSignedIn()
        && resource.data.studentEmail.lower() == request.auth.token.email.lower());
      allow update, delete: if isAdmin();
    }

    // Material Progress
    match /materialProgress/{progressId} {
      allow read, write: if isAdmin() || (isSignedIn()
        && resource.data.studentEmail.lower() == request.auth.token.email.lower());
      allow create: if isSignedIn();
    }
  }
}
